{
  "info": {
    "name": "Case Review Workflow API",
    "description": "API collection for the Case Review Workflow System. Features automatic case_id extraction.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin123"
    },
    {
      "key": "case_id",
      "value": ""
    },
    {
      "key": "reviewer_id",
      "value": "REPLACE_WITH_REVIEWER_UUID",
      "description": "Create a Reviewer user in Django Admin and paste their UUID here to test assignment."
    }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "password",
        "value": "{{password}}",
        "type": "string"
      },
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Cases",
      "item": [
        {
          "name": "Create Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.case_id) {",
                  "    pm.collectionVariables.set(\"case_id\", jsonData.case_id);",
                  "    console.log(\"Saved case_id: \" + jsonData.case_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Fraud Investigation - TX\",\n    \"description\": \"Suspicious transactions flagged in Texas region.\",\n    \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cases/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                ""
              ]
            }
          }
        },
        {
          "name": "List Cases",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cases/?ordering=-created_at&page=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                ""
              ],
              "query": [
                {
                  "key": "status",
                  "value": "draft",
                  "disabled": true
                },
                {
                  "key": "priority",
                  "value": "high",
                  "disabled": true
                },
                {
                  "key": "ordering",
                  "value": "-created_at"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Case",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                ""
              ]
            }
          }
        },
        {
          "name": "Update Case",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"priority\": \"critical\",\n    \"description\": \"UPDATED: Suspicious transactions flagged in Texas region. Escalating due to volume.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Workflow & Assignment",
      "item": [
        {
          "name": "Assign Case",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"assigned_to\": \"{{reviewer_id}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/assign/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                "assign",
                ""
              ]
            }
          }
        },
        {
          "name": "Transition Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"pending_review\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/transition/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                "transition",
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Comments & Audit",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Investigating the transaction logs now. Looks highly suspicious.\",\n    \"is_internal\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/comments/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                "comments",
                ""
              ]
            }
          }
        },
        {
          "name": "List Comments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/comments/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                "comments",
                ""
              ]
            }
          }
        },
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{case_id}}/audit-logs/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cases",
                "{{case_id}}",
                "audit-logs",
                ""
              ]
            }
          }
        }
      ]
    }
  ]
}